{
  "id": "researcher",
  "name": "Researcher",
  "description": "Web research specialist that produces structured, sourced research briefings",
  "version": "1.0",

  "agent_type": "specialist",

  "execution": {
    "context": "fork",
    "max_turns": 20,
    "model": "sonnet"
  },

  "expertise": {
    "domains": ["web research", "information synthesis", "source evaluation"],
    "capabilities": ["web search", "web fetch", "structured briefing"]
  },

  "mcp_servers": [],

  "context_buckets": {
    "assigned": [],
    "access_level": "read-only"
  },

  "output": {
    "folder": "outputs/research/",
    "formats": ["markdown"]
  },

  "collaboration": {
    "can_request_from": [],
    "provides_to": ["writer"],
    "handoff_format": "structured-summary"
  },

  "trigger": {
    "type": "on-demand",
    "description": "Invoked when the user asks a factual research question or when another agent needs sourced evidence"
  }
}
