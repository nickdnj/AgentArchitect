{
  "id": "improver",
  "name": "Agent Improver",
  "description": "Meta-agent that reads agent feedback logs and proposes improvements to SKILL.md files. The core of the self-improving agent loop.",
  "version": "1.0",
  "expertise": {
    "domains": ["agent-design", "behavioral-analysis", "instruction-engineering"],
    "capabilities": ["feedback-analysis", "skill-editing", "pattern-recognition", "diff-generation"]
  },
  "mcp_servers": [],
  "context_buckets": {
    "assigned": [],
    "access_level": "read-only"
  },
  "output": {
    "folder": "outputs/",
    "formats": ["markdown"]
  },
  "collaboration": {
    "can_request_from": [],
    "provides_to": [],
    "handoff_format": "structured-summary"
  },
  "trigger": {
    "type": "on-demand",
    "description": "Invoked after sufficient task feedback accumulates for an agent (minimum 3 entries)"
  },
  "agent_type": "utility",
  "execution": {
    "context": "fork",
    "max_turns": 30,
    "model": "opus"
  }
}
