{
  "id": "proposal-review",
  "name": "Proposal Review",
  "description": "Analyzes vendor proposals and delivers structured assessments via email",
  "version": "1.0",
  "expertise": {
    "domains": [
      "vendor analysis",
      "contract review",
      "risk assessment"
    ],
    "capabilities": [
      "proposal extraction",
      "comparative analysis",
      "cost evaluation",
      "recommendation generation"
    ]
  },
  "mcp_servers": [
    "gmail"
  ],
  "context_buckets": {
    "assigned": [
      "wharfside-docs"
    ],
    "access_level": "read-only",
    "_note": "wharfside-docs is the FTS5 RAG bucket for governing-doc full-text search. Kept alongside wiki_access by design."
  },

  "wiki_access": {
    "repo_root": "${WIKI_REPO}",
    "read": [
      "spine/network/",
      "spine/infrastructure/",
      "teams/wharfside/"
    ],
    "write_via_ingest": [],
    "session_log": "teams/wharfside/_sessions/proposal-review/",
    "always_load": [
      "spine/preferences/seven-habits-of-effective-agents.md",
      "teams/wharfside/_team.md"
    ]
  },
  "output": {
    "folder": "outputs/",
    "formats": [
      "markdown",
      "html-email"
    ],
    "email_iteration": {
      "enabled": true,
      "template": "wharfside-report",
      "subject_format": "Vendor Proposal Analysis: {vendor} - v{version}",
      "google_doc_finalize": true
    }
  },
  "collaboration": {
    "can_request_from": [
      "archivist"
    ],
    "provides_to": [
      "presentation"
    ],
    "handoff_format": "structured-summary"
  },
  "trigger": {
    "type": "on-demand",
    "description": "Triggered when user requests proposal review"
  },
  "gmail": {
    "account": "nickd@wharfsidemb.com",
    "search_terms": [
      "proposal",
      "quote",
      "bid",
      "estimate",
      "pricing"
    ],
    "attachment_types": [
      "pdf",
      "docx",
      "xlsx"
    ]
  },
  "notifications": {
    "email": "nickd@wharfsidemb.com"
  },
  "analysis": {
    "risk_thresholds": {
      "high_deposit_percentage": 50,
      "unusual_price_variance": 30
    }
  },
  "agent_type": "specialist",
  "execution": {
    "context": "fork",
    "max_turns": 20,
    "model": "sonnet"
  }
}
