{
  "id": "monthly-bulletin",
  "name": "Monthly Bulletin",
  "description": "Generates monthly community bulletin for Wharfside Manor as HTML email with nautical theme",
  "version": "3.0",
  "expertise": {
    "domains": [
      "community communications",
      "newsletter creation",
      "content curation"
    ],
    "capabilities": [
      "email mining",
      "content organization",
      "HTML email generation",
      "work order analysis"
    ]
  },
  "mcp_servers": [
    "gmail"
  ],
  "context_buckets": {
    "assigned": [
      "wharfside-docs"
    ],
    "access_level": "read-only",
    "_note": "wharfside-docs is the FTS5 RAG bucket for governing-doc full-text search. Kept alongside wiki_access by design — RAG bucket bytes do not duplicate into the wiki; the wiki references them by URL/ID. See docs/architecture/wiki-knowledge-base.md."
  },

  "wiki_access": {
    "repo_root": "${WIKI_REPO}",
    "read": [
      "spine/preferences/",
      "spine/network/",
      "spine/infrastructure/",
      "teams/wharfside/"
    ],
    "write_via_ingest": [
      "teams/wharfside/bulletins/"
    ],
    "session_log": "teams/wharfside/_sessions/monthly-bulletin/",
    "always_load": [
      "spine/preferences/seven-habits-of-effective-agents.md",
      "teams/wharfside/_team.md",
      "spine/preferences/bulletin-publishing-workflow.md"
    ]
  },
  "output": {
    "folder": "outputs/",
    "formats": [
      "html-email"
    ],
    "email_iteration": {
      "enabled": true,
      "template": "wharfside-report",
      "subject_format": "{month} {year} Monthly Bulletin - v{version}",
      "google_doc_finalize": false
    }
  },
  "collaboration": {
    "can_request_from": [
      "archivist",
      "email-research"
    ],
    "provides_to": [],
    "handoff_format": "structured-summary"
  },
  "trigger": {
    "type": "scheduled",
    "schedule": {
      "cron": "0 9 25 * *",
      "description": "9:00 AM on the 25th of every month",
      "timezone": "America/New_York"
    }
  },
  "gmail": {
    "account": "nickd@wharfsidemb.com",
    "lookback_days": 30
  },
  "logo": {
    "url": "https://raw.githubusercontent.com/nickdnj/wharfside-assets/master/Wharfside_Logo_Cropped.png",
    "alt_text": "Wharfside Manor",
    "width": "180px"
  },
  "email": {
    "to": "nickd@wharfsidemb.com",
    "subject_format": "{month} {year} Monthly Bulletin - Draft v{version}",
    "mime_type": "text/html"
  },
  "agent_type": "specialist",
  "execution": {
    "context": "fork",
    "max_turns": 25,
    "model": "sonnet"
  }
}
