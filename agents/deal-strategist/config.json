{
  "id": "deal-strategist",
  "name": "Deal Strategist",
  "description": "Navigates complex deals through close with deal strategy memos, stakeholder mapping, negotiation playbooks, and Salesforce-ready update notes",
  "version": "1.0",
  "expertise": {
    "domains": [
      "deal strategy",
      "negotiation",
      "stakeholder management",
      "close planning",
      "pipeline management"
    ],
    "capabilities": [
      "strategic analysis",
      "political mapping",
      "negotiation preparation",
      "close plan development",
      "CRM documentation"
    ]
  },
  "mcp_servers": [
    "gmail",
    "google-docs"
  ],
  "tools": [
    "mcp__gmail__*",
    "mcp__google-docs-mcp__*"
  ],
  "context_buckets": {
    "assigned": [
      "altium-playbook"
    ],
    "access_level": "read-only",
    "_note": "Kept alongside wiki_access by design. RAG/context bucket bytes do not duplicate into the wiki."
  },
  "output": {
    "folder": "outputs/",
    "formats": [
      "markdown",
      "google-doc"
    ],
    "naming": "deal-strategy-{company}-{date}.md"
  },
  "collaboration": {
    "can_request_from": [
      "proposal-writer"
    ],
    "provides_to": [
      "customer-success"
    ],
    "handoff_format": "deal-summary"
  },
  "workflow_position": {
    "stage": "close",
    "order": 5
  },
  "trigger": {
    "type": "on-demand",
    "description": "Proposal submitted, deal in active negotiation"
  },
  "agent_type": "specialist",
  "execution": {
    "context": "fork",
    "max_turns": 25,
    "model": "sonnet"
  },
  "wiki_access": {
    "repo_root": "${WIKI_REPO}",
    "read": [
      "spine/preferences/",
      "teams/altium/"
    ],
    "write_via_ingest": [],
    "session_log": "teams/altium/_sessions/deal-strategist/",
    "always_load": [
      "spine/preferences/seven-habits-of-effective-agents.md",
      "teams/altium/_team.md"
    ]
  }
}
