{
  "id": "account-researcher",
  "name": "Account Researcher",
  "description": "Researches prospects and accounts before engagement, producing comprehensive account briefs with company overview, tech stack, industry context, recent news, and key stakeholders",
  "version": "1.0",
  "expertise": {
    "domains": [
      "account research",
      "prospect intelligence",
      "technology stack analysis",
      "stakeholder mapping",
      "sales enablement"
    ],
    "capabilities": [
      "web research",
      "LinkedIn analysis",
      "company profiling",
      "news monitoring",
      "stakeholder identification"
    ]
  },
  "mcp_servers": [
    "gmail",
    "google-drive"
  ],
  "tools": [
    "WebSearch",
    "WebFetch",
    "mcp__chrome__*",
    "mcp__gmail__*",
    "mcp__google-drive__*"
  ],
  "context_buckets": {
    "assigned": [
      "altium-playbook"
    ],
    "access_level": "read-only",
    "_note": "Kept alongside wiki_access by design. RAG/context bucket bytes do not duplicate into the wiki."
  },
  "output": {
    "folder": "outputs/",
    "formats": [
      "markdown",
      "html-email"
    ],
    "naming": "account-brief-{company}-{date}.md"
  },
  "collaboration": {
    "can_request_from": [
      "chrome-browser"
    ],
    "provides_to": [
      "qualification-analyst"
    ],
    "handoff_format": "account-brief"
  },
  "workflow_position": {
    "stage": "discovery",
    "entry_point": true,
    "order": 1
  },
  "trigger": {
    "type": "on-demand",
    "description": "New lead received or expansion research requested"
  },
  "agent_type": "specialist",
  "execution": {
    "context": "fork",
    "max_turns": 20,
    "model": "sonnet"
  },
  "wiki_access": {
    "repo_root": "${WIKI_REPO}",
    "read": [
      "spine/preferences/",
      "teams/altium/"
    ],
    "write_via_ingest": [],
    "session_log": "teams/altium/_sessions/account-researcher/",
    "always_load": [
      "spine/preferences/seven-habits-of-effective-agents.md",
      "teams/altium/_team.md"
    ]
  }
}
