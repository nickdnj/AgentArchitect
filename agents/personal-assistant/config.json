{
  "id": "personal-assistant",
  "name": "Max - Personal Assistant",
  "description": "Nick's personal assistant with persistent research caching, email management, document creation, and knowledge management.",
  "version": "1.0",
  "persona": {
    "name": "Max",
    "style": "friendly, direct, organized, proactive"
  },
  "expertise": {
    "domains": [
      "research",
      "email-management",
      "document-creation",
      "knowledge-management",
      "task-tracking",
      "information-retrieval"
    ],
    "capabilities": [
      "web-research-with-caching",
      "email-search-and-drafting",
      "google-docs-creation",
      "google-drive-search",
      "to-do-management",
      "project-tracking",
      "research-report-generation",
      "cross-reference-cached-research"
    ]
  },
  "mcp_servers": [
    "gmail",
    "gmail-personal",
    "google-drive",
    "google-docs",
    "voicemode",
    "pdfscribe",
    "gtasks",
    "apple-mcp",
    "apple-contacts",
    "openai-image"
  ],
  "context_buckets": {
    "assigned": [
      "research-cache",
      "personal-notes",
      "ai-journey"
    ],
    "access_level": "read-write",
    "_note": "Max's RAG buckets: research-cache (persistent cache for non-trivial research outputs, pgvector), personal-notes (Nick's running notes), ai-journey (Nick's AI/coding journey). Kept alongside wiki_access by design — the wiki is curated knowledge; these buckets are ephemeral working memory."
  },

  "wiki_access": {
    "repo_root": "${WIKI_REPO}",
    "read": [
      "spine/",
      "teams/personal-assistant/"
    ],
    "write_via_ingest": [],
    "session_log": "teams/personal-assistant/_sessions/",
    "always_load": [
      "spine/preferences/seven-habits-of-effective-agents.md",
      "teams/personal-assistant/_team.md",
      "spine/preferences/email-account-routing.md"
    ]
  },
  "output": {
    "folder": "outputs/",
    "formats": [
      "markdown",
      "google-docs"
    ]
  },
  "collaboration": {
    "can_request_from": [
      "chrome-browser"
    ],
    "provides_to": [],
    "handoff_format": "structured-summary"
  },
  "trigger": {
    "type": "on-demand",
    "description": "Invoked when Nick needs personal assistance - research, email, documents, notes, or task management"
  },
  "rag_integration": {
    "enabled": true,
    "database": {
      "type": "postgres+pgvector",
      "host": "localhost",
      "port": 5433,
      "name": "rag"
    },
    "default_bucket": "research-cache",
    "available_buckets": ["research-cache", "personal-notes", "session-logs"],
    "cli_path": "/Users/nickd/Workspaces/pdfscribe_cli",
    "env_vars": {
      "RAG_BACKEND": "postgres",
      "RAG_DB_HOST": "127.0.0.1",
      "RAG_DB_PORT": "5433"
    }
  },
  "research_cache": {
    "bucket": "research-cache",
    "path": "context-buckets/research-cache/files/",
    "naming": "YYYY-MM-DD_topic-slug.md",
    "staleness_days": 30,
    "check_before_research": true
  },
  "agent_type": "orchestrator",
  "execution": {
    "context": "inline",
    "max_turns": 50,
    "model": "opus"
  },
  "delegation": {
    "available_specialists": [
      "web-research",
      "chrome-browser",
      "rag-search",
      "pdf-scribe"
    ],
    "parallel_allowed": true,
    "briefing_required": false
  }
}
