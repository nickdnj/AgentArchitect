{
  "id": "qualification-analyst",
  "name": "Qualification Analyst",
  "description": "Assesses technical and business fit against Altium's ICP, producing MEDDPICC qualification scorecards with recommended next steps and red flag identification",
  "version": "1.0",
  "expertise": {
    "domains": [
      "sales qualification",
      "MEDDPICC methodology",
      "ICP alignment",
      "deal assessment",
      "sales process optimization"
    ],
    "capabilities": [
      "qualification scoring",
      "red flag identification",
      "next step recommendations",
      "handoff preparation",
      "pipeline analysis"
    ]
  },
  "mcp_servers": [
    "gmail",
    "google-docs"
  ],
  "tools": [
    "mcp__gmail__*",
    "mcp__google-docs-mcp__*"
  ],
  "context_buckets": {
    "assigned": [
      "altium-playbook"
    ],
    "access_level": "read-only",
    "_note": "Kept alongside wiki_access by design. RAG/context bucket bytes do not duplicate into the wiki."
  },
  "output": {
    "folder": "outputs/",
    "formats": [
      "markdown",
      "google-doc"
    ],
    "naming": "qualification-{company}-{date}.md"
  },
  "collaboration": {
    "can_request_from": [
      "account-researcher"
    ],
    "provides_to": [
      "solution-architect",
      "value-engineer"
    ],
    "handoff_format": "qualification-scorecard"
  },
  "workflow_position": {
    "stage": "discovery",
    "order": 2
  },
  "trigger": {
    "type": "on-demand",
    "description": "Account brief received, discovery call completed"
  },
  "agent_type": "specialist",
  "execution": {
    "context": "fork",
    "max_turns": 20,
    "model": "sonnet"
  },
  "wiki_access": {
    "repo_root": "${WIKI_REPO}",
    "read": [
      "spine/preferences/",
      "teams/altium/"
    ],
    "write_via_ingest": [],
    "session_log": "teams/altium/_sessions/qualification-analyst/",
    "always_load": [
      "spine/preferences/seven-habits-of-effective-agents.md",
      "teams/altium/_team.md"
    ]
  }
}
