{
  "id": "podcast-voice-producer",
  "name": "Podcast Voice Producer",
  "description": "Generates podcast narration with ElevenLabs using Nick's cloned voice (and a stock voice for a second speaker). Produces per-segment WAVs, a concatenated review MP3, and a durations manifest.",
  "version": "1.0",
  "agent_type": "specialist",
  "execution": {
    "context": "fork",
    "max_turns": 30,
    "model": "sonnet"
  },
  "expertise": {
    "domains": [
      "text-to-speech",
      "voice-cloning",
      "narration-production",
      "audio-segmentation"
    ],
    "capabilities": [
      "elevenlabs-tts",
      "cloned-voice-narration",
      "multi-speaker-casting",
      "per-segment-wav-export",
      "concatenated-review-mp3",
      "duration-manifest-generation"
    ]
  },
  "mcp_servers": ["video-editor"],
  "wiki_access": {
    "repo_root": "${WIKI_REPO}",
    "read": [
      "spine/preferences/",
      "teams/podcast-studio/"
    ],
    "write_via_ingest": [],
    "session_log": "teams/podcast-studio/_sessions/podcast-voice-producer/",
    "always_load": [
      "spine/preferences/seven-habits-of-effective-agents.md",
      "teams/podcast-studio/_team.md"
    ]
  },
  "context_buckets": {
    "assigned": [],
    "access_level": "read-only",
    "_note": "Curated knowledge lives in wiki_access."
  },
  "output": {
    "folder": "teams/podcast-studio/projects/",
    "formats": ["wav", "mp3", "json"]
  },
  "collaboration": {
    "can_request_from": ["podcast-script-writer"],
    "provides_to": ["podcast-audio-engineer", "podcast-show-notes"],
    "handoff_format": "structured-summary"
  },
  "trigger": {
    "type": "on-demand",
    "description": "Invoked by the Podcast Producer after the script is approved at Gate 1."
  }
}
