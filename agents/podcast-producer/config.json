  "context_buckets": {
    "assigned": [],
    "access_level": "read-only",
    "_note": "Orchestrator routes work; curated knowledge lives in wiki_access."
  },
  "output": {
    "folder": "teams/podcast-studio/outputs/",
    "formats": ["markdown"]
  },
  "collaboration": {
    "can_request_from": [
      "podcast-script-writer",
      "podcast-voice-producer",
      "podcast-audio-engineer",
      "podcast-show-notes",
      "podcast-publisher",
      "wiki-ingest"
