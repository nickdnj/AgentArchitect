{
  "id": "podcast-producer",
  "name": "Podcast Producer",
  "description": "Orchestrator for the Podcast Studio team. Reads a research report or story brief, chooses the episode format, runs the scriptâ†’voiceâ†’masterâ†’notesâ†’publish pipeline, and owns the two human review gates.",
  "version": "1.0",
  "agent_type": "orchestrator",
  "execution": {
    "context": "inline",
    "max_turns": 50,
    "model": "opus"
  },
  "expertise": {
    "domains": [
      "podcast-production",
      "editorial-format-selection",
      "pipeline-orchestration",
      "review-gate-management"
