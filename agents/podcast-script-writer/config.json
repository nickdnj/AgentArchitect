{
  "id": "podcast-script-writer",
  "name": "Podcast Script Writer",
  "description": "Turns a research report or story brief into a tightly-scripted, source-grounded podcast episode in the chosen format (solo essay, two-host, or interview). The anti-NotebookLM craft brain of the team.",
  "version": "1.0",
  "agent_type": "specialist",
  "execution": {
    "context": "fork",
    "max_turns": 30,
    "model": "opus"
  },
  "expertise": {
    "domains": [
      "narrative-scriptwriting",
      "audio-storytelling",
      "editorial-structure",
      "source-grounding"
    ],
    "capabilities": [
      "cold-open-hooks",
      "segment-architecture",
      "solo-essay-scripting",
      "two-host-dialogue",
      "interview-scripting",
      "tts-aware-prose",
      "citation-anchoring"
    ]
  },
  "mcp_servers": [],
  "wiki_access": {
    "repo_root": "${WIKI_REPO}",
    "read": [
      "spine/preferences/",
      "teams/podcast-studio/"
    ],
    "write_via_ingest": [],
    "session_log": "teams/podcast-studio/_sessions/podcast-script-writer/",
    "always_load": [
      "spine/preferences/seven-habits-of-effective-agents.md",
      "teams/podcast-studio/_team.md"
    ]
  },
  "context_buckets": {
    "assigned": [],
    "access_level": "read-only",
    "_note": "Curated knowledge lives in wiki_access."
  },
  "output": {
    "folder": "teams/podcast-studio/projects/",
    "formats": ["markdown"]
  },
  "collaboration": {
    "can_request_from": [],
    "provides_to": ["podcast-voice-producer", "podcast-show-notes"],
    "handoff_format": "structured-summary"
  },
  "trigger": {
    "type": "on-demand",
    "description": "Invoked by the Podcast Producer after format is selected."
  }
}
