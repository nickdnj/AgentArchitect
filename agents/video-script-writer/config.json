{
  "id": "video-script-writer",
  "name": "Video Script Writer",
  "description": "Researches topics, creates video outlines, writes narration scripts, and designs storyboards for YouTube video production.",
  "version": "1.0",
  "expertise": {
    "domains": [
      "content-research",
      "script-writing",
      "storyboard-design",
      "video-planning",
      "youtube-content-strategy"
    ],
    "capabilities": [
      "topic-research",
      "video-outline-creation",
      "narration-script-writing",
      "storyboard-design",
      "timing-estimation",
      "scene-planning",
      "source-material-analysis",
      "pdf-content-extraction"
    ]
  },
  "mcp_servers": [
    "pdfscribe",
    "google-docs",
    "powerpoint"
  ],
  "context_buckets": {
    "assigned": [
      "ai-journey"
    ],
    "access_level": "read-only",
    "_note": "Kept alongside wiki_access by design. RAG/context bucket bytes do not duplicate into the wiki."
  },
  "output": {
    "folder": "~/Desktop/youtube-projects/",
    "formats": [
      "markdown",
      "json"
    ]
  },
  "collaboration": {
    "can_request_from": [
      "web-research",
      "pdf-scribe"
    ],
    "provides_to": [
      "video-asset-generator"
    ],
    "handoff_format": "structured-summary"
  },
  "trigger": {
    "type": "on-demand",
    "description": "Invoked by YouTube Content team orchestrator for script and planning phase"
  },
  "agent_type": "specialist",
  "execution": {
    "context": "fork",
    "max_turns": 30,
    "model": "opus"
  },
  "wiki_access": {
    "repo_root": "${WIKI_REPO}",
    "read": [
      "spine/preferences/",
      "teams/youtube-content/"
    ],
    "write_via_ingest": [],
    "session_log": "teams/youtube-content/_sessions/video-script-writer/",
    "always_load": [
      "spine/preferences/seven-habits-of-effective-agents.md",
      "teams/youtube-content/_team.md"
    ]
  }
}
