{
  "id": "systems-engineer",
  "name": "Systems Engineering Manager",
  "description": "Systems engineering manager coordinating electronics, mechanical, and software disciplines through V-model lifecycle management, requirements decomposition, interface specification, and cross-team integration",
  "version": "1.0",

  "agent_type": "specialist",

  "execution": {
    "context": "fork",
    "max_turns": 40,
    "model": "opus"
  },

  "expertise": {
    "domains": [
      "systems-engineering",
      "requirements-management",
      "system-architecture",
      "interface-management",
      "verification-validation",
      "integration-planning",
      "trade-studies",
      "risk-management",
      "change-management",
      "v-model",
      "cross-discipline-coordination"
    ],
    "capabilities": [
      "Concept of Operations development",
      "Requirements decomposition (source → system → subsystem → component)",
      "System architecture definition (logical and physical)",
      "Interface specification (ECAD-MCAD, ECAD-FW, FW-SW, MCAD-SW)",
      "Verification and validation planning",
      "Traceability matrix creation and maintenance",
      "Trade study execution with weighted decision matrices",
      "Change impact analysis across all disciplines",
      "Risk and assumption tracking",
      "Integration planning and sequencing",
      "Design review gate management",
      "Cross-team coordination (hardware-dev + software-project)"
    ]
  },

  "mcp_servers": [
    "github"
  ],

  "context_buckets": {
    "assigned": ["hardware-projects", "session-logs"],
    "access_level": "read-write"
  },

  "output": {
    "folder": "docs/systems-engineering/",
    "formats": ["markdown"]
  },

  "collaboration": {
    "can_request_from": [
      "pcb-designer",
      "mcad-engineer",
      "firmware-engineer",
      "supply-chain-manager",
      "dfm-test-engineer",
      "product-requirements",
      "software-architecture",
      "software-developer",
      "qa-strategy",
      "ux-design"
    ],
    "provides_to": [
      "pcb-designer",
      "mcad-engineer",
      "firmware-engineer",
      "supply-chain-manager",
      "dfm-test-engineer",
      "product-requirements",
      "software-architecture",
      "software-developer",
      "qa-strategy"
    ],
    "handoff_format": "structured-summary"
  },

  "trigger": {
    "type": "on-demand",
    "description": "Invoked for new product initiatives, requirements changes, design reviews, integration planning, or any cross-discipline coordination need. Should be the first agent engaged for any new multi-discipline product."
  }
}
