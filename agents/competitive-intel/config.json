{
  "id": "competitive-intel",
  "name": "Competitive Intelligence",
  "description": "Monitors competitors and provides positioning guidance through battle cards, objection handling, and win/loss analysis for Cadence, Mentor/Siemens, KiCad, and other EDA competitors",
  "version": "1.0",
  "expertise": {
    "domains": [
      "competitive analysis",
      "EDA market intelligence",
      "sales enablement",
      "objection handling",
      "win/loss analysis"
    ],
    "capabilities": [
      "battle card development",
      "competitor monitoring",
      "positioning strategy",
      "objection response creation",
      "pattern analysis"
    ]
  },
  "mcp_servers": [
    "google-docs"
  ],
  "tools": [
    "WebSearch",
    "WebFetch",
    "mcp__chrome__*",
    "mcp__google-docs-mcp__*"
  ],
  "context_buckets": {
    "assigned": [
      "altium-playbook"
    ],
    "access_level": "read-write",
    "_note": "Kept alongside wiki_access by design. RAG/context bucket bytes do not duplicate into the wiki."
  },
  "output": {
    "folder": "outputs/",
    "formats": [
      "markdown",
      "google-doc"
    ],
    "naming": "battle-card-{competitor}-{date}.md"
  },
  "collaboration": {
    "can_request_from": [
      "chrome-browser"
    ],
    "provides_to": [
      "solution-architect",
      "proposal-writer"
    ],
    "handoff_format": "battle-card"
  },
  "workflow_position": {
    "stage": "support",
    "parallel_with_any": true,
    "order": 0
  },
  "trigger": {
    "type": "on-demand",
    "description": "Competitive situation in deal, RFP support, or periodic monitoring"
  },
  "agent_type": "specialist",
  "execution": {
    "context": "fork",
    "max_turns": 20,
    "model": "sonnet"
  },
  "wiki_access": {
    "repo_root": "${WIKI_REPO}",
    "read": [
      "spine/preferences/",
      "teams/altium/"
    ],
    "write_via_ingest": [],
    "session_log": "teams/altium/_sessions/competitive-intel/",
    "always_load": [
      "spine/preferences/seven-habits-of-effective-agents.md",
      "teams/altium/_team.md"
    ]
  }
}
