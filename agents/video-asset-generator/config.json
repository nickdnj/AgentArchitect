{
  "id": "video-asset-generator",
  "name": "Video Asset Generator",
  "description": "Generates visual assets (AI images), narration audio (TTS), and background music for YouTube video production.",
  "version": "1.0",
  "expertise": {
    "domains": [
      "ai-image-generation",
      "text-to-speech",
      "audio-production",
      "visual-asset-creation"
    ],
    "capabilities": [
      "gpt-image-2-generation",
      "gpt-image-2-thinking-mode",
      "dalle3-image-generation",
      "gpt-image-generation",
      "tts-narration-generation",
      "kokoro-tts-fallback",
      "ambient-music-generation",
      "image-processing",
      "audio-normalization",
      "user-photo-processing"
    ]
  },
  "mcp_servers": [
    "openai-image",
    "voicemode",
    "video-editor"
  ],
  "context_buckets": {
    "assigned": [
      "ai-journey"
    ],
    "access_level": "read-only",
    "_note": "Kept alongside wiki_access by design. RAG/context bucket bytes do not duplicate into the wiki."
  },
  "output": {
    "folder": "~/Desktop/youtube-projects/",
    "formats": [
      "png",
      "wav",
      "json"
    ]
  },
  "collaboration": {
    "can_request_from": [
      "video-script-writer"
    ],
    "provides_to": [
      "video-assembler"
    ],
    "handoff_format": "structured-summary"
  },
  "trigger": {
    "type": "on-demand",
    "description": "Invoked by YouTube Content team orchestrator after script/storyboard is complete"
  },
  "agent_type": "specialist",
  "execution": {
    "context": "fork",
    "max_turns": 40,
    "model": "sonnet"
  },
  "wiki_access": {
    "repo_root": "${WIKI_REPO}",
    "read": [
      "spine/preferences/",
      "teams/youtube-content/"
    ],
    "write_via_ingest": [],
    "session_log": "teams/youtube-content/_sessions/video-asset-generator/",
    "always_load": [
      "spine/preferences/seven-habits-of-effective-agents.md",
      "teams/youtube-content/_team.md"
    ]
  }
}
