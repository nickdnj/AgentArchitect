{
  "id": "social-distributor",
  "name": "Social Distributor",
  "description": "Plans and executes social media launch campaigns for each published video \u2014 pre-premiere buzz, launch day posts, and follow-up across YouTube Community, Facebook groups, Reddit, Instagram, and TikTok.",
  "version": "1.0",
  "expertise": {
    "domains": [
      "social-media-marketing",
      "community-engagement",
      "hyper-local-promotion",
      "youtube-premieres",
      "content-distribution",
      "audience-growth"
    ],
    "capabilities": [
      "platform-specific-copywriting",
      "community-targeting",
      "premiere-scheduling",
      "teaser-content-creation",
      "facebook-group-strategy",
      "reddit-community-engagement",
      "instagram-caption-writing",
      "email-campaign-drafting",
      "launch-calendar-creation",
      "post-performance-tracking"
    ]
  },
  "mcp_servers": [
    "chrome",
    "gmail-personal"
  ],
  "context_buckets": {
    "assigned": [
      "ai-journey"
    ],
    "access_level": "read-only",
    "_note": "Kept alongside wiki_access by design. RAG/context bucket bytes do not duplicate into the wiki."
  },
  "output": {
    "folder": "social/",
    "formats": [
      "markdown",
      "json"
    ],
    "folder_note": "Relative to the current project repo root (factory model: projects are standalone repos provisioned by aa new; see AgentArchitect/docs/factory-model.md)"
  },
  "collaboration": {
    "can_request_from": [
      "video-publisher",
      "short-form-video",
      "chrome-browser"
    ],
    "provides_to": [],
    "handoff_format": "structured-summary"
  },
  "trigger": {
    "type": "on-demand",
    "description": "Invoked by YouTube Content team orchestrator after video is published or scheduled as a premiere"
  },
  "agent_type": "specialist",
  "execution": {
    "context": "fork",
    "max_turns": 30,
    "model": "sonnet"
  },
  "wiki_access": {
    "repo_root": "${WIKI_REPO}",
    "read": [
      "spine/preferences/",
      "teams/youtube-content/"
    ],
    "write_via_ingest": [],
    "session_log": "teams/youtube-content/_sessions/social-distributor/",
    "always_load": [
      "spine/preferences/seven-habits-of-effective-agents.md",
      "teams/youtube-content/_team.md"
    ]
  }
}
