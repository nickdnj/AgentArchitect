{
  "id": "migration-specialist",
  "name": "Migration Specialist",
  "description": "Design data migration expert specializing in converting legacy EDA tool data (Cadence, Mentor, EAGLE, KiCad) to Altium format including library conversion and validation",
  "version": "1.0",
  "expertise": {
    "domains": [
      "EDA tool migration",
      "Cadence conversion",
      "Mentor conversion",
      "EAGLE conversion",
      "KiCad conversion",
      "library migration"
    ],
    "capabilities": [
      "migration assessment",
      "library conversion",
      "design conversion",
      "data validation",
      "netlist comparison"
    ]
  },
  "mcp_servers": [
    "google-docs"
  ],
  "tools": [
    "WebSearch",
    "WebFetch",
    "mcp__chrome__*",
    "mcp__google-docs-mcp__*"
  ],
  "context_buckets": {
    "assigned": [
      "altium-playbook"
    ],
    "access_level": "read-only",
    "_note": "Kept alongside wiki_access by design. RAG/context bucket bytes do not duplicate into the wiki."
  },
  "output": {
    "folder": "outputs/",
    "formats": [
      "markdown",
      "google-doc"
    ],
    "naming": "migration-{company}-{date}.md"
  },
  "collaboration": {
    "can_request_from": [
      "deployment-manager",
      "chrome-browser"
    ],
    "coordinates_with": [
      "ecad-specialist"
    ],
    "provides_to": [
      "deployment-manager"
    ],
    "handoff_format": "migration-report"
  },
  "workflow_position": {
    "stage": "deployment",
    "domain": "migration",
    "order": 3
  },
  "trigger": {
    "type": "on-demand",
    "description": "Migration workstream activated"
  },
  "agent_type": "specialist",
  "execution": {
    "context": "fork",
    "max_turns": 20,
    "model": "sonnet"
  },
  "wiki_access": {
    "repo_root": "${WIKI_REPO}",
    "read": [
      "spine/preferences/",
      "teams/altium/"
    ],
    "write_via_ingest": [],
    "session_log": "teams/altium/_sessions/migration-specialist/",
    "always_load": [
      "spine/preferences/seven-habits-of-effective-agents.md",
      "teams/altium/_team.md"
    ]
  }
}
