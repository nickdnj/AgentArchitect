# Saltwater AI Ads — production environment template
# Copy to .env and fill in actual values. Do NOT check .env into git.

# ===== Vendor API keys =====

# Anthropic (Claude) — required for hook generation.
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# HeyGen — required for the founder hook clip layer.
# Get from https://app.heygen.com/settings/api
# HEYGEN_AVATAR_ID = the photo-avatar ID for Joe (created in HeyGen dashboard)
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=

# Fashn.ai — required for the try-on showcase layer.
# Get from https://app.fashn.ai/account/api-keys
FASHN_API_KEY=

# Triple Whale — required for per-ad performance attribution.
# Get from https://app.triplewhale.com (Settings → API Keys, Premium plan only).
TRIPLEWHALE_API_KEY=

# Resend — required for magic-link sign-in delivery.
# Get from https://resend.com/api-keys (free tier: 3000 emails/month).
RESEND_API_KEY=re_...

# ===== Auth =====

# 32-byte hex secrets for HMAC-signed cookies + media URL signing.
# Generate with: openssl rand -hex 32
SESSION_SECRET=
SIGNING_KEY=

# Comma-separated list of operator emails allowed to sign in.
ALLOWED_OPERATORS=joe@saltwaterlongisland.com,nickd@demarconet.com

# ===== Email + paging =====

# From-address for magic-link emails. Must be a verified Resend domain.
MAGIC_LINK_FROM=Saltwater Ads <noreply@saltwater-ads.example.com>

# Where on-call alerts go.
NICK_PAGE_TO=nickd@demarconet.com

# ===== Public URL =====

# Used in magic-link email bodies. Must match Caddy DOMAIN below.
PUBLIC_BASE_URL=https://saltwater-ads.example.com
DOMAIN=saltwater-ads.example.com
