{
  "name": "saltwater-ads",
  "version": "0.1.0",
  "private": true,
  "description": "Saltwater AI Ads — Sprint 1 web app. Generate / Review / Settings for Joe DeMarco's brand-locked AI ad pipeline. Bun + Hono + Vite + React + bun:sqlite. See ../../docs/saltwater-ads/{PRD,SAD,UXD}.md.",
  "module": "src/server/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:server": "bun --hot src/server/index.ts",
    "dev:worker": "bun --hot src/worker/poll-jobs.ts",
    "dev:web": "vite",
    "build:web": "vite build",
    "start:server": "bun src/server/index.ts",
    "start:worker": "bun src/worker/poll-jobs.ts",
    "db:migrate": "bun db/migrate.ts",
    "db:backup": "bun db/backup.ts",
    "test": "bun test",
    "test:integration": "bun test test/integration",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "hono": "^4.6.0",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "msw": "^2.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
