#!/usr/bin/env bash
# Otto — your offline second brain. Bare `otto` drops into the chat;
# `otto doctor`, `otto ask "…"`, `otto index`, `otto handoff` etc. still work.
# Install on PATH:  ln -sf "$PWD/otto" /opt/homebrew/bin/otto
# Resolves symlinks so it finds scribe.py wherever it really lives.
src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ $src != /* ]] && src="$dir/$src"
done
dir="$(cd -P "$(dirname "$src")" && pwd)"
exec python3 "$dir/scribe.py" "$@"
